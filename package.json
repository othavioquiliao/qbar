{
  "name": "agent-bar-omarchy",
  "version": "3.0.0",
  "description": "LLM quota monitor for Waybar - Claude, Codex, Amp",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "agent-bar-omarchy": "./scripts/agent-bar-omarchy"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "lint": "bunx biome check",
    "lint:fix": "bunx biome check --write"
  },
  "keywords": [
    "waybar",
    "claude",
    "codex",
    "llm",
    "quota"
  ],
  "author": "Othavio",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/bun": "latest",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "1.0.0",
    "ora": "9.3.0"
  }
}
