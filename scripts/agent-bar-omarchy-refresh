#!/usr/bin/env bash
# agent-bar-omarchy-refresh - Force refresh with spinner in floating terminal
# Usage: agent-bar-omarchy-refresh [provider]

PROVIDER="${1:-}"
APP_DIR="$(dirname "$(readlink -f "$0")")/.."

cd "$APP_DIR" || exit 1

if [[ -n "$PROVIDER" ]]; then
  bun src/refresh.ts "$PROVIDER"
else
  bun src/refresh.ts
fi

# Keep terminal open briefly to show result
sleep 1
